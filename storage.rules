rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isSosercomAdmin() {
      return userDoc().role == "super_admin_global" || userDoc().role == "admin";
    }

    function belongsToTenant(tenantId) {
      return isAuth() && userDoc().tenantId == tenantId;
    }

    function casePath(caseId) {
      return /databases/(default)/documents/cases/$(caseId);
    }

    function isCaseClient(caseId) {
      return firestore.exists(casePath(caseId)) &&
        firestore.get(casePath(caseId)).data.clientId == request.auth.uid;
    }

    match /vault/{tenantId}/{caseId}/{fileName=**} {
      allow read, write: if isAuth() && (
        isSosercomAdmin() ||
        belongsToTenant(tenantId) ||
        isCaseClient(caseId)
      );
    }
  }
}
